@model BearcatBites.Models.FoodItem?

@{
    ViewData["Title"] = "Daily Spotlight";
}

<div class="text-center my-5">
    <h1 class="display-4 fw-bold">Daily Spotlight</h1>
    <p class="lead mt-2">Daily recommendation from Cincinnati's best bites &amp; sips!</p>
</div>

@if (Model == null)
{
    <div class="text-center my-5">
        <p class="text-muted">No entries in the database yet. Add some bites or sips from the admin panel!</p>
    </div>
}
else
{
    <div class="row justify-content-center my-4">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                @if (!string.IsNullOrEmpty(Model.ImagePath))
                {
                    <img src="@Model.ImagePath" class="card-img-top" alt="@Model.Name"
                         style="height: 280px; object-fit: cover;" />
                }
                <div class="card-body text-center p-4">
                    <span class="badge mb-2" style="background-color: var(--pp-green); font-size: 0.85rem;">
                        @Model.Type.ToString()
                    </span>
                    <h2 class="card-title fw-bold mt-1">@Model.Name</h2>
                    <h6 class="text-muted mb-3">@Model.Restaurant</h6>
                    <p class="card-text">@Model.Description</p>
                </div>
            </div>
        </div>
    </div>
}