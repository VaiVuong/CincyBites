@{
    ViewData["Title"] = "About Us";
}

<div class="hero-section text-center my-4">
    <h1 class="display-4 fw-bold">About Us</h1>
    <p class="lead mt-3">
        We're a small team of Cincinnati locals with a shared love for great food
        and the communities that create it — dedicated to the Queen City!
    </p>
</div>

<div class="row mt-5 text-center">
    <div class="col-md-4 mb-4">
        <h4 style="color: var(--pp-green);">Our Mission</h4>
        <p>
            To celebrate the diverse culinary traditions found across Cincinnati's
            neighborhoods and connect food lovers with hidden gems they might
            otherwise miss.
        </p>
    </div>
    <div class="col-md-4 mb-4">
        <h4 style="color: var(--pp-green);">What We Cover</h4>
        <p>
            From bowls of Vietnamese Pho and Indian Panipuri, to mugs of Coffee and cups of Boba.
            We explore everything Cincinnati has to offer to eat!
        </p>
    </div>
    <div class="col-md-4 mb-4">
        <h4 style="color: var(--pp-green);">Why Cincinnati?</h4>
        <p>
            Cincinnati is home to an incredible mix of cultures, and its food
            scene reflects that beautifully. We're here to explore every flavor
            the Queen City has to offer.
        </p>
    </div>
</div>

<div class="container mt-5 py-4">
    <h2 class="text-center fw-bold mb-5">Meet the Developers</h2>

    <div class="row justify-content-center">
        <div class="col-md-5 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body text-center p-4">
                    <h3 class="fw-bold mb-3" style="color: var(--pp-green); font-size: 1.8rem;">Chris Vu</h3>
                    <p class="text-muted">
                        Student at University of Cincinnati, majoring in IT Software Development and minoring in Computer Science. Currently works at the college as a fulltime IT staff member. Grew up in a Vietnamese household and the greater Cincinnati Area.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-5 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body text-center p-4">
                    <h3 class="fw-bold mb-3" style="color: var(--pp-green); font-size: 1.8rem;">Pranish Adhikari</h3>
                    <p class="text-muted">
                        PRANISH ADD YOUR INFO HERE PLEASE
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
